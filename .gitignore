# ---------------------------------------------------------------------
# VS 2022 / MSBuild 中间目录与输出目录
# ---------------------------------------------------------------------
# 每个 vcxproj 工程都会生成存放 .obj / .tlog / .res / .idb / 中间 pdb 等
# 纯产物的「配置目录」。本仓库各工程对这些目录的命名并不统一，常见有：
#   Debug/  Release/                          —— 经典默认名
#   Debug_x64/  Release_x64/  Debug_Win32/    —— 带平台后缀
#   Static_Debug_Win32/  Static_Release_x64/  —— 静态库工程的命名
# 旧规则写成 */Debug/ 只能匹配一层深，像 Bin/Static/Win32/Debug/ 这种更深、
# 或 Debug_x64 这种变体命名都会漏网。这里改用「按目录名在任意层级匹配」的
# 写法整目录忽略，避免新工程换个命名又得回来补规则。
[Dd]ebug/
[Dd]ebug_*/
[Rr]elease/
[Rr]elease_*/
Static_*/
x64/
[Ww]in32/
ARM/
ARM64/
ipch/
# MSBuild 增量编译的 *.tlog 目录(可出现在各配置目录下)。
*.tlog/

# 解决方案级的 .vs/ 目录里是 VS 的本机 IDE 缓存 / IntelliSense 数据库 /
# 浏览数据，规模大且和机器绑定。
.vs/


# ---------------------------------------------------------------------
# VS 用户态 / 解决方案缓存
# ---------------------------------------------------------------------
# 每用户每机器一份，绝不能进版本控制。
*.user
*.suo
*.sln.docstates
*.aps
*.sdf
*.opensdf
*.VC.db
*.VC.opendb
*.ncb


# ---------------------------------------------------------------------
# Bin/ —— 产物按扩展名忽略，保留真实资产 (*.png / *.xml / *.ini …)
# ---------------------------------------------------------------------
# Bin/Static/ 是脚本批量编译静态库时收集 .lib / .pdb / 反汇编等的输出目录，
# 整棵子树都是产物，直接整目录忽略。
Bin/Static/
# Bin/ 根目录下的可执行 / 调试符号 / 构建日志等产物按扩展名忽略；
# 而 BuddyInfoDlgBg.png、chat.xml、frame-*.xml 这类真实资产保留下来。
Bin/*.exe
Bin/*.dll
Bin/*.pdb
Bin/*.ilk
Bin/*.exp
Bin/*.lib
Bin/*.iobj
Bin/*.ipdb
Bin/*.idb
Bin/*.map
Bin/*.log
Bin/*.tlog


# ---------------------------------------------------------------------
# 编辑器 / 操作系统垃圾
# ---------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
*.swp
*~
