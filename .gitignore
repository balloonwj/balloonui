# ---------------------------------------------------------------------
# VS 2022 / MSBuild 中间目录
# ---------------------------------------------------------------------
# 每个 vcxproj 工程都会生成 Debug/ Release/ x64/ 子目录存放 .obj/.tlog/
# .res/.idb/中间 pdb 等纯产物，整目录可以忽略。
*/Debug/
*/Release/
*/x64/
*/Win32/
*/ARM/
*/ARM64/
*/ipch/

# 解决方案级的 .vs/ 目录里是 VS 的本机 IDE 缓存 / IntelliSense 数据库 /
# 浏览数据，规模大且和机器绑定。
.vs/


# ---------------------------------------------------------------------
# VS 用户态 / 解决方案缓存
# ---------------------------------------------------------------------
# 每用户每机器一份，绝不能进版本控制。
*.user
*.suo
*.sln.docstates
*.aps
*.sdf
*.opensdf
*.VC.db
*.VC.opendb
*.ncb


# ---------------------------------------------------------------------
# Bin/ —— 产物按扩展名忽略，保留真实资产 (*.png / *.xml / *.ini …)
# ---------------------------------------------------------------------
Bin/*.exe
Bin/*.dll
Bin/*.pdb
Bin/*.ilk
Bin/*.exp
Bin/*.lib
Bin/*.iobj
Bin/*.ipdb
Bin/*.idb
Bin/*.map
Bin/*.log
Bin/*.tlog


# ---------------------------------------------------------------------
# 编辑器 / 操作系统垃圾
# ---------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
*.swp
*~
